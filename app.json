{
  "expo": {
    "name": "Guia do Aventureiro",
    "slug": "guia-aventureiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "guiaaventureiro",
    "userInterfaceStyle": "automatic",
    "description": "Planeje suas viagens com Inteligência Artificial. Roteiros personalizados, controle de orçamento e muito mais!",
    "privacy": "public",
    "platforms": ["ios", "android"],
    "primaryColor": "#005A8D",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#005A8D"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.guiaaventureiro.app",
      "supportsTablet": true,
      "buildNumber": "1.0.0",
      "associatedDomains": [
        "applinks:share.guiaaventureiro.app",
        "applinks:share.guiaaventureiro.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir acesso à câmera para tirar fotos dos seus roteiros.",
        "NSPhotoLibraryUsageDescription": "Permitir acesso à galeria para adicionar fotos aos roteiros.",
        "NSLocationWhenInUseUsageDescription": "Usar sua localização para sugerir destinos próximos.",
        "NSUserNotificationUsageDescription": "Permitir notificações para receber lembretes e alertas de viagem.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.guiaaventureiro.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#005A8D"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "share.guiaaventureiro.app",
              "pathPrefix": "/r"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir acesso à localização para sugerir destinos próximos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#005A8D",
          "sounds": [],
          "mode": "production"
        }
      ],
      "@react-native-firebase/app"
    ],
    "extra": {
      "eas": {
        "projectId": "54bc8b24-11a9-4960-af7d-5fb784639f83"
      }
    }
  }
}
