# Environment variables template for Expo app
# Copy this file to .env.local and fill in the actual values
# NEVER commit .env.local to version control

# Ambiente do app: local | production
EXPO_PUBLIC_APP_ENV=local

# Google Maps API Key (get it from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Dev API URL (local development)
EXPO_PUBLIC_LOCAL_API_URL=http://192.168.1.100:3000/api
EXPO_PUBLIC_DEV_API_URL=http://localhost:3000/api

# Production API URL
EXPO_PUBLIC_PROD_API_URL=https://your-api-domain.com/api
